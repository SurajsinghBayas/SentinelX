# ─── SentinelX Environment Configuration ─────────────────────────────────────
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=SentinelX
APP_VERSION=1.0.0
DEBUG=false
ENV=production

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://sentinelx:sentinelx_pass@postgres:5432/sentinelx_db

# ─── Redis & Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── JWT ──────────────────────────────────────────────────────────────────────
# IMPORTANT: Generate a secure random 256-bit key for production!
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ─── ML Models ────────────────────────────────────────────────────────────────
NLP_MODEL_NAME=distilbert-base-uncased
WHISPER_MODEL_SIZE=base
ML_CACHE_DIR=/app/ml_cache
USE_GPU=false

# ─── External APIs (Optional) ─────────────────────────────────────────────────
# VIRUSTOTAL_API_KEY=your_virustotal_key_here
# PHISHTANK_API_KEY=your_phishtank_key_here

# ─── Risk Thresholds ──────────────────────────────────────────────────────────
RISK_THRESHOLD_LOW=30
RISK_THRESHOLD_MEDIUM=60
RISK_THRESHOLD_HIGH=85
ALERT_TRIGGER_THRESHOLD=61

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
